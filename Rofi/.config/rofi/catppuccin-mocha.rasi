/* VERY Modified */
* {
  bg-col:  #11111b;
  bg-col-light: #1e1e2e;
  border-col: #1e1e2e;
  selected-col: #1e1e2e;
  blue: #89b4fa;
  fg-col: #cdd6f4;
  fg-col2: #f38ba8;
  grey: #6c7086;


  background-color: @bg-col;
  text-color: @fg-col;
}

selected {
    text-color: #f38ba8;
    font-weight: 900;
}
